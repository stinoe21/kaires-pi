# ── Output adapter ─────────────────────────────────────────────────────
# sonos | alsa | dlna  (alleen sonos is geïmplementeerd in MVP)
KAIRES_OUTPUT=sonos

# Optioneel: hint IP als SSDP-discovery faalt (bv. multicast geblokkeerd)
# KAIRES_SONOS_HINT_IP=192.168.1.50

# ── Mode ───────────────────────────────────────────────────────────────
# 1 = test-playlist mode (3 hardcoded MP3s, geen Supabase nodig — voor
#     on-site UPnP-validatie zonder live data)
# 0 = library mode (DNA + realtime context + CAS-ranked tracks uit Supabase)
KAIRES_USE_TEST_PLAYLIST=0

# ── Store identity ─────────────────────────────────────────────────────
# Vereist in library-mode. UUID van de store-row in Supabase.
KAIRES_STORE_ID=
KAIRES_STORE_NAME=

# ── Supabase ────────────────────────────────────────────────────────────
# Vereist in library-mode. Anon key, geen service role.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Tuning ──────────────────────────────────────────────────────────────
KAIRES_PULSE_INTERVAL_MS=60000
KAIRES_TRACK_END_POLL_MS=5000
KAIRES_HEARTBEAT_INTERVAL_MS=30000
KAIRES_APP_VERSION=pi-dev

# Test-playback URL (alleen gebruikt door src/play-test.mjs)
KAIRES_TEST_AUDIO_URL=https://archive.org/download/testmp3testfile/mpthreetest.mp3
