# ── Output adapter ─────────────────────────────────────────────────────
# sonos     — UPnP push naar Sonos (productie)
# lan-http  — Pi serveert audio via HTTP, MacBook/browser/Sonos pulled (test)
# alsa | dlna — nog niet geïmplementeerd
KAIRES_OUTPUT=lan-http

# Optionele fallback. In productie kiest de operator/klant de speaker via
# het webapp-dashboard (Audio Output panel) — de Pi pikt die keuze op via
# Supabase realtime. Deze hint is alleen nuttig wanneer er nog geen DB-target
# is gezet (bv. lokale dev, eerste boot zonder dashboard-toegang).
# KAIRES_SONOS_HINT_IP=192.168.1.50

# ── Mode ───────────────────────────────────────────────────────────────
# 1 = test-playlist mode (3 hardcoded MP3s, geen Supabase nodig — voor
#     on-site UPnP-validatie zonder live data)
# 0 = library mode (DNA + realtime context + CAS-ranked tracks uit Supabase)
KAIRES_USE_TEST_PLAYLIST=0

# ── Store identity ─────────────────────────────────────────────────────
# Vereist in library-mode. UUID van de store-row in Supabase.
KAIRES_STORE_ID=
KAIRES_STORE_NAME=

# ── Supabase ────────────────────────────────────────────────────────────
# Vereist in library-mode. Publishable key (sb_publishable_...), niet de
# legacy JWT anon key — die is project-side disabled per 2026-04-28. De env
# var heet nog SUPABASE_ANON_KEY voor backwards compat met webapp-naming;
# de waarde mag het nieuwe sb_publishable_ formaat zijn. Geen service role.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Pi auth-user ───────────────────────────────────────────────────────
# Eén dedicated auth-user per store. Moet in Supabase Authentication zijn
# aangemaakt en als store_users-rij gelinkt aan de bedoelde KAIRES_STORE_ID.
# Zonder deze user blokkeert RLS pilot_heartbeat-, playlist_log-, en
# retailer_music_dna-toegang.
KAIRES_PI_EMAIL=
KAIRES_PI_PASSWORD=

# ── LAN HTTP server (alleen relevant in lan-http output mode) ──────────
KAIRES_HTTP_PORT=8000
KAIRES_HTTP_BIND=0.0.0.0

# ── Audio cache ─────────────────────────────────────────────────────────
KAIRES_CACHE_DIR=audio-cache
KAIRES_CACHE_MAX_FILES=20

# ── Tuning ──────────────────────────────────────────────────────────────
KAIRES_PULSE_INTERVAL_MS=60000
KAIRES_TRACK_END_POLL_MS=5000
KAIRES_HEARTBEAT_INTERVAL_MS=30000
KAIRES_APP_VERSION=pi-dev

# Test-playback URL (alleen gebruikt door src/play-test.mjs)
KAIRES_TEST_AUDIO_URL=https://archive.org/download/testmp3testfile/mpthreetest.mp3
