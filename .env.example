# Output adapter — sonos | alsa | dlna
KAIRES_OUTPUT=sonos

# Optional: hint IP if SSDP discovery fails (e.g. multicast-blocked networks)
# KAIRES_SONOS_HINT_IP=192.168.1.50

# Store identity — used for heartbeat + library queries
KAIRES_STORE_ID=
KAIRES_STORE_NAME=

# Supabase (read from VITE_SUPABASE_* in webapp .env)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Test playback URL for sanity script
KAIRES_TEST_AUDIO_URL=https://archive.org/download/testmp3testfile/mpthreetest.mp3
